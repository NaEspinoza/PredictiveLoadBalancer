# LB
LB_PORT=8080
LB_READ_TIMEOUT=5s
LB_WRITE_TIMEOUT=20s
LB_IDLE_TIMEOUT=60s
LB_HEALTHCHECK_PATH=/health
LB_HEALTHCHECK_INTERVAL=5s
LB_ALPHA_DT=0.1
LB_ALPHA_TAU=10.0
LB_WEIGHT_LAT=0.7
LB_WEIGHT_CONN=0.3
LB_ERR_PENALTY_MS=500

# Backends

Recomendado: crear un repo en GitHub, copiar/pegar esta estructura y ajustar variables de entorno.
BACKEND1=http://backend1:9001
BACKEND2=http://backend2:9002
BACKEND3=http://backend3:9003

# Prometheus
PROM_PORT=9090
